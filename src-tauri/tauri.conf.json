{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "CoolMessenger Tenor Picker",
    "identifier": "com.banatic.tenor-picker",
    "version": "0.1.3",
    "build": {
        "frontendDist": "../src"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Tenor Picker",
                "width": 420,
                "height": 580,
                "resizable": false,
                "decorations": false,
                "alwaysOnTop": true,
                "transparent": true,
                "visible": false,
                "skipTaskbar": true,
                "center": false,
                "x": 0,
                "y": 0
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}